DISCORD_TOKEN=your-bot-token-here
GUILD_ID=your-server-id-here
DEFAULT_CWD=/path/to/your/working/directory
CODEX_BIN=codex
CODEX_MODEL=
OPENAI_API_KEY=

# Guild allowlist for message/slash gates. CSV. If empty, falls back to GUILD_ID.
# If both ALLOWED_GUILD_IDS and GUILD_ID are empty, all guild messages are rejected.
ALLOWED_GUILD_IDS=

# Channel allowlist for message/slash gates. CSV. Empty accepts all channels in allowed guilds.
ALLOWED_CHANNEL_IDS=

# DM user allowlist. CSV. Empty rejects all DMs.
ALLOWED_DM_USER_IDS=

# Path-prefix blocklist for Codex workdirs and /cd. CSV.
SENSITIVE_PATH_BLOCKLIST=${HOME}/.ssh,${HOME}/.aws,${HOME}/.codex,${HOME}/.claude,/etc,/root

# Optional per-thread workdir root. If set, new threads use <root>/discord-<thread_id>/.
THREAD_WORKDIR_ROOT=

# Per-user requests allowed per rolling wall-clock hour bucket.
CODEX_RATE_LIMIT_PER_USER_HOUR=30
