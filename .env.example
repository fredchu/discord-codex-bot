DISCORD_TOKEN=your-bot-token-here
GUILD_ID=your-server-id-here
DEFAULT_CWD=/path/to/your/working/directory
CODEX_BIN=codex
CODEX_SANDBOX=workspace-write
CODEX_MODEL=
OPENAI_API_KEY=

# Per-user requests allowed per rolling wall-clock hour bucket.
CODEX_RATE_LIMIT_PER_USER_HOUR=30

# Per-channel daily token caps tracked from Codex usage after successful replies.
CODEX_TOKEN_CAP_PER_CHANNEL_DAY_INPUT=500000
CODEX_TOKEN_CAP_PER_CHANNEL_DAY_OUTPUT=100000
